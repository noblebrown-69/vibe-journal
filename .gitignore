# Build artifacts - keeps git history clean by ignoring compiled binaries and build dirs
vj
*.o
build/
dist/
__pycache__/
*.tar.gz
*.zip
# Temporary files - autosave drafts and SQLite temp files not for version control
autosave.temp
*.db-journal
# Editor junk - VS Code settings and vim swap files clutter repo
.vscode/
*.swp
# DB lock - SQLite lock file, not portable across machines
vibe_journal.db-journal
*.swp
*.swo
*~

# macOS
.DS_Store

# Misc
*.docx
*.spec
